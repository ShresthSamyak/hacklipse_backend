APP_ENV=development
DEBUG=true

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:<password>@db.<supabase-project>.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Redis (for caching / pub-sub)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-me-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── Primary LLM (Groq) ────────────────────────────────────────────────────────
LLM_PROVIDER=groq
LLM_API_KEY=your-groq-api-key
LLM_MODEL=llama3-70b-8192
LLM_BASE_URL=                     # leave blank — Groq uses its own base URL
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=2

# ── Fast / lightweight LLM (optional) ────────────────────────────────────────
# Used for low-stakes tasks (summarisation, question rephrase, etc.)
# Leave blank to disable; orchestrator will fall back to primary LLM.
FAST_LLM_PROVIDER=gemini
FAST_LLM_API_KEY=                 # separate key if provider differs
FAST_LLM_MODEL=gemma2-9b-it        # fastest Groq-hosted OSS model; swap as needed

# ── Speech-to-Text (Groq Whisper) ─────────────────────────────────────────────
ASR_PROVIDER=groq
ASR_MODEL=whisper-large-v3-turbo
ASR_LANGUAGE=                     # optional: ISO 639-1 code (e.g. "en", "hi")
ASR_MAX_FILE_BYTES=26214400       # 25 MB — Groq's current limit

# ── Application ───────────────────────────────────────────────────────────────
PROJECT_NAME="Narrative Merge Engine"
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=console                # json | console
