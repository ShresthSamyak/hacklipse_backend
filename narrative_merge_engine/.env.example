# ==============================================================================
# Narrative Merge Engine - Environment Configuration
# ==============================================================================

# ── App Config ────────────────────────────────────────────────────────────────
# General application environment and server prefix settings.
APP_ENV=development
DEBUG=true
PROJECT_NAME="Narrative Merge Engine"
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────────
# Database connection string using asyncpg driver. 
# Defaults below showcase a local setup, modify username/password/host for Supabase.
DATABASE_URL=postgresql+asyncpg://postgres:your-db-password@localhost:5432/postgres
DATABASE_MAX_OVERFLOW=20

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis is necessary for caching results, pub-sub messaging, & strict rate limiting.
REDIS_URL=redis://localhost:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Cryptographic variables for JWT token security headers and session state.
SECRET_KEY=change-me-to-a-secure-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ── LLM (Primary) ─────────────────────────────────────────────────────────────
# This core LLM is routed for structured reasoning tasks like Timeline Reconstruction,
# Event Extraction, and Conflict resolution mapping.
# Using Groq exclusively per architecture directives.
LLM_PROVIDER=groq
LLM_API_KEY=                                      # REPLACE with actual `gsk_` key
LLM_MODEL=llama-3.3-70b-versatile
LLM_TEMPERATURE=0.0                               # Set to 0.0 for heavily deterministic outputs
LLM_TIMEOUT_SECONDS=60                            # Grace period before timing out inference delays
LLM_MAX_RETRIES=2

# ── LLM (Fast) ────────────────────────────────────────────────────────────────
# Used as a fast, lightweight delegator for parsing or preview generation scenarios.
# Orchestrator will seamlessly fall backward to primary model if leaving it blank.
FAST_LLM_PROVIDER=groq
FAST_LLM_API_KEY=                                 # Keep blank to reuse the primary LLM_API_KEY
FAST_LLM_MODEL=llama-3.1-8b-instant
FAST_LLM_TIMEOUT_SECONDS=15                       # Tighter timeout for fast preview branches

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# Configuration dedicated to transcribing multi-witness inputs efficiently.
ASR_PROVIDER=groq
ASR_MODEL=whisper-large-v3-turbo
ASR_LANGUAGE=en                                     # Optional: Explicit ISO 639-1 code (e.g. "en")
ASR_MAX_FILE_BYTES=26214400                       # Fixed 25 MB cutoff (Groq API restriction bound)
ASR_TIMEOUT_SECONDS=30                            # Speech to text inference timeout block

# ── Logging ───────────────────────────────────────────────────────────────────
# Structural observability configuration to export logic. 
# In production, LOG_FORMAT should be 'json'.
LOG_LEVEL=INFO
LOG_FORMAT=console
